---
interface Props {
  href?: string;
  showWordmark?: boolean;
}
const { href = "/", showWordmark = true } = Astro.props;
---
<a href={href} aria-label="Real Estate Intent — home" style="display:inline-flex; align-items:center; gap:10px;">
  <span class="logo-mark" aria-hidden="true">
    <svg viewBox="0 0 56 56" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M12 36 L28 18 L44 36" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="28" cy="18" r="5" fill="white"/>
    </svg>
  </span>
  {showWordmark && (
    <span style="display:flex; flex-direction:column;">
      <span class="wordmark-1">Real Estate Intent</span>
      <span class="wordmark-2">Audience intelligence</span>
    </span>
  )}
</a>
