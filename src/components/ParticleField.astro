---
---
<canvas class="particle-field" id="particle-field" aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById("particle-field") as HTMLCanvasElement | null;
  if (canvas) {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const ctx = canvas.getContext("2d", { alpha: true });
    if (!ctx) {
      canvas.style.display = "none";
    } else {
      type P = { x: number; y: number; vx: number; vy: number; size: number; color: string; baseAlpha: number; phase: number };
      const COLORS = ["#F87171", "#FBBF24", "#4ADE80", "#A78BFA", "#7DD3FC"];
      const pickColor = () => COLORS[Math.floor(Math.random() * COLORS.length)];

      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      let W = 0, H = 0;
      let particles: P[] = [];
      let rafId = 0;
      const parent = canvas.parentElement;

      function resize() {
        const rect = parent?.getBoundingClientRect();
        W = rect?.width ?? window.innerWidth;
        H = rect?.height ?? window.innerHeight;
        canvas.width = W * dpr;
        canvas.height = H * dpr;
        canvas.style.width = W + "px";
        canvas.style.height = H + "px";
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function spawn() {
        const area = W * H;
        const count = Math.min(140, Math.max(60, Math.round(area / 12000)));
        particles = new Array(count).fill(0).map(() => ({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.08,
          vy: -0.02 - Math.random() * 0.05,
          size: 0.9 + Math.random() * 1.1,
          color: pickColor(),
          baseAlpha: 0.18 + Math.random() * 0.18,
          phase: Math.random() * Math.PI * 2,
        }));
      }

      function tick(t: number) {
        ctx.clearRect(0, 0, W, H);
        const time = t * 0.0008;
        for (const p of particles) {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < -4) p.x = W + 4;
          else if (p.x > W + 4) p.x = -4;
          if (p.y < -4) p.y = H + 4;
          else if (p.y > H + 4) p.y = -4;

          const breathe = 0.9 + Math.sin(time + p.phase) * 0.1;
          ctx.fillStyle = p.color;
          ctx.globalAlpha = p.baseAlpha * breathe;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
        rafId = requestAnimationFrame(tick);
      }

      function drawStatic() {
        ctx.clearRect(0, 0, W, H);
        for (const p of particles) {
          ctx.fillStyle = p.color;
          ctx.globalAlpha = p.baseAlpha;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
      }

      function start() {
        resize();
        spawn();
        if (prefersReduced) {
          drawStatic();
          return;
        }
        rafId = requestAnimationFrame(tick);
      }

      start();

      window.addEventListener("resize", () => {
        cancelAnimationFrame(rafId);
        resize();
        spawn();
        if (prefersReduced) drawStatic();
        else rafId = requestAnimationFrame(tick);
      });

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) cancelAnimationFrame(rafId);
        else if (!prefersReduced) rafId = requestAnimationFrame(tick);
      });
    }
  }
</script>
