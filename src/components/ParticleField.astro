---
---
<canvas class="particle-field" id="particle-field" aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById("particle-field") as HTMLCanvasElement | null;
  if (canvas) {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const ctx = canvas.getContext("2d", { alpha: true });
    if (!ctx) {
      canvas.style.display = "none";
    } else {
      type P = { x: number; y: number; vx: number; vy: number; size: number; color: string; alpha: number; baseAlpha: number; phase: number };
      const COLORS = ["#F87171", "#FBBF24", "#4ADE80", "#A78BFA", "#7DD3FC"];
      const WEIGHTS = [0.18, 0.20, 0.26, 0.22, 0.14];
      const pickColor = () => {
        const r = Math.random();
        let acc = 0;
        for (let i = 0; i < COLORS.length; i++) {
          acc += WEIGHTS[i];
          if (r < acc) return COLORS[i];
        }
        return COLORS[0];
      };

      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      let W = 0, H = 0;
      let particles: P[] = [];
      let mouseX = -9999, mouseY = -9999;
      let mouseActive = false;
      let rafId = 0;
      const hero = canvas.parentElement;

      function resize() {
        const rect = hero?.getBoundingClientRect();
        W = rect?.width ?? window.innerWidth;
        H = rect?.height ?? window.innerHeight;
        canvas.width = W * dpr;
        canvas.height = H * dpr;
        canvas.style.width = W + "px";
        canvas.style.height = H + "px";
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function spawn() {
        const area = W * H;
        const count = Math.min(420, Math.max(180, Math.round(area / 3800)));
        particles = new Array(count).fill(0).map(() => ({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.25,
          vy: (Math.random() - 0.5) * 0.1 - 0.05,
          size: 1 + Math.random() * 1.6,
          color: pickColor(),
          alpha: 0,
          baseAlpha: 0.3 + Math.random() * 0.35,
          phase: Math.random() * Math.PI * 2,
        }));
      }

      function onMove(e: MouseEvent) {
        const rect = canvas.getBoundingClientRect();
        mouseX = e.clientX - rect.left;
        mouseY = e.clientY - rect.top;
        mouseActive = true;
      }
      function onLeave() { mouseActive = false; }

      function tick(t: number) {
        ctx.clearRect(0, 0, W, H);
        ctx.globalCompositeOperation = "lighter";
        const time = t * 0.001;
        for (const p of particles) {
          if (mouseActive) {
            const dx = mouseX - p.x;
            const dy = mouseY - p.y;
            const d2 = dx * dx + dy * dy;
            if (d2 < 44100) {
              const d = Math.sqrt(d2) || 1;
              const pull = (1 - d / 210) * 0.06;
              p.vx += (dx / d) * pull;
              p.vy += (dy / d) * pull;
            }
          }
          p.vx *= 0.965;
          p.vy *= 0.965;
          p.vx += (Math.random() - 0.5) * 0.015;
          p.vy += (Math.random() - 0.5) * 0.01;
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < -10) p.x = W + 10;
          else if (p.x > W + 10) p.x = -10;
          if (p.y < -10) p.y = H + 10;
          else if (p.y > H + 10) p.y = -10;

          const flicker = 0.85 + Math.sin(time * 1.4 + p.phase) * 0.15;
          const a = p.baseAlpha * flicker;

          ctx.fillStyle = p.color;
          ctx.globalAlpha = a * 0.55;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size * 2.6, 0, Math.PI * 2);
          ctx.fill();

          ctx.globalAlpha = a;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
        rafId = requestAnimationFrame(tick);
      }

      function drawStatic() {
        ctx.clearRect(0, 0, W, H);
        ctx.globalCompositeOperation = "lighter";
        for (const p of particles) {
          ctx.fillStyle = p.color;
          ctx.globalAlpha = p.baseAlpha * 0.7;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
      }

      function start() {
        resize();
        spawn();
        if (prefersReduced) {
          drawStatic();
          return;
        }
        rafId = requestAnimationFrame(tick);
      }

      start();

      window.addEventListener("resize", () => {
        cancelAnimationFrame(rafId);
        resize();
        spawn();
        if (prefersReduced) drawStatic();
        else rafId = requestAnimationFrame(tick);
      });

      if (hero) {
        hero.addEventListener("mousemove", onMove);
        hero.addEventListener("mouseleave", onLeave);
      }

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) cancelAnimationFrame(rafId);
        else if (!prefersReduced) rafId = requestAnimationFrame(tick);
      });
    }
  }
</script>
