---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Logo from '../components/Logo.astro';
import ParticleField from '../components/ParticleField.astro';

const businessName = "Real Estate Intent";
const tagline = "Behavioral Audience Intelligence for Real Estate";
const description = "See the buyers, sellers, and distressed homeowners who are already showing intent — before they ever hit Zillow. 7-day free trial.";
const siteUrl = (Astro.site ?? Astro.url.origin).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": businessName,
      "url": siteUrl,
      "logo": `${siteUrl}favicon.svg`,
      "parentOrganization": { "@type": "Organization", "name": "Go Next Level" }
    },
    {
      "@type": "SoftwareApplication",
      "name": businessName,
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": description,
      "offers": [
        { "@type": "Offer", "name": "Starter", "price": "1000", "priceCurrency": "USD" },
        { "@type": "Offer", "name": "Growth", "price": "2500", "priceCurrency": "USD" },
        { "@type": "Offer", "name": "Scale", "price": "5000", "priceCurrency": "USD" }
      ]
    }
  ]
};

const behaviors = [
  {
    accent: "distress", title: "Distress",
    desc: "Homeowners engaging with pre-foreclosure content, loan modification tools, and financial hardship resources.",
  },
  {
    accent: "seller", title: "Seller",
    desc: "People browsing listing platforms, researching home values, and comparing agent reviews in your market.",
  },
  {
    accent: "buyer", title: "Buyer",
    desc: "Prospects saving listings, attending virtual open houses, and researching neighborhoods they want to move to.",
  },
  {
    accent: "mortgage", title: "Mortgage",
    desc: "Households running affordability calculators, comparing lenders, and engaging with refinance tools.",
  },
];

const steps = [
  { n: "01", title: "Monitor", body: "We watch real behavioral signals across the open web — the kind that actually precede a move." },
  { n: "02", title: "Filter",  body: "Narrow by intent category, market, and recency until the list matches the deals you want to close." },
  { n: "03", title: "Export",  body: "Push to your CRM or download a CSV. Refreshes weekly — you only pay for net-new contacts." },
];

const plans = [
  { name: "Starter", price: "$1,000", contacts: "1,000", seats: "1", featured: false,
    features: ["All four intent categories", "CSV export + CRM push", "Weekly behavioral refresh", "7-day free trial"] },
  { name: "Growth",  price: "$2,500", contacts: "3,500", seats: "3", featured: true,
    features: ["Everything in Starter", "Auto-refreshing lists", "Multi-market builds", "Priority support"] },
  { name: "Scale",   price: "$5,000", contacts: "10,000", seats: "10", featured: false,
    features: ["Everything in Growth", "Dedicated success manager", "Custom CRM integrations", "Volume pricing"] },
];
---

<BaseLayout
  title={`${businessName} — ${tagline}`}
  description={description}
  structuredData={structuredData}
>
  <Topbar />

  <main>
    <!-- 1. HERO -->
    <section class="hero" id="hero">
      <div class="hero-glow"></div>
      <ParticleField />
      <div class="hero-vignette"></div>

      <div class="container hero-inner">
        <span class="chip" data-reveal>
          <span style="width:6px;height:6px;border-radius:50%;background:var(--brand);box-shadow:0 0 8px var(--brand);"></span>
          Audience intelligence for real estate
        </span>

        <h1 class="hero-h1" data-reveal>
          Real behaviors. Real contacts. <em class="gradient-text">Before</em> they hit Zillow.
        </h1>

        <p class="lead hero-lead" data-reveal>
          See the buyers, sellers, and distressed homeowners already showing intent — sliced by category and market, refreshed every week.
        </p>

        <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center;" data-reveal>
          <a href="/signup" class="btn btn-primary">
            Start 7-day free trial
            <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#pricing" class="btn btn-ghost">See pricing</a>
        </div>
      </div>
    </section>

    <!-- 2. FOUR BEHAVIORS -->
    <section class="section" id="behaviors">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow" data-reveal>Four behaviors. One contact list.</span>
          <h2 class="section-title" data-reveal>
            Not <em class="gradient-text">who</em> they are. <em class="gradient-text">What</em> they're doing.
          </h2>
        </div>

        <div class="behaviors-grid">
          {behaviors.map((b) => (
            <article class="behavior-card" data-accent={b.accent} data-reveal>
              <span class="behavior-accent">
                <span class="accent-dot"></span>
                {b.title}
              </span>
              <h3 class="behavior-title">{b.title}</h3>
              <p class="behavior-desc">{b.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. HOW IT WORKS -->
    <section class="section" id="how">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow" data-reveal>How it works</span>
          <h2 class="section-title" data-reveal>
            From signal to <em class="gradient-text">verified contact</em>.
          </h2>
        </div>

        <div class="how-grid">
          {steps.map((s) => (
            <div class="how-step" data-reveal>
              <span class="how-num mono">{s.n}</span>
              <h3 class="how-title">{s.title}</h3>
              <p class="how-body">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. PRICING -->
    <section class="section" id="pricing">
      <div class="container">
        <div class="section-head" style="text-align:center; align-items:center; margin-left:auto; margin-right:auto;">
          <span class="eyebrow" data-reveal>Pricing</span>
          <h2 class="section-title" data-reveal>Start free. <em class="gradient-text">Scale</em> when you're ready.</h2>
          <p class="lead" data-reveal style="max-width:500px;">7-day free trial on every plan.</p>
        </div>

        <div class="plan-grid">
          {plans.map((p) => (
            <article class="plan-card" data-featured={p.featured} data-reveal>
              {p.featured && <span class="plan-badge">Most popular</span>}
              <div>
                <h3 class="plan-name">{p.name}</h3>
                <div class="plan-price">
                  <span class="price">{p.price}</span>
                  <span class="price-suffix">/ mo</span>
                </div>
              </div>

              <ul class="plan-features">
                <li>
                  <span class="plan-check">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                  {p.contacts} contacts / mo
                </li>
                <li>
                  <span class="plan-check">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                  {p.seats} {p.seats === "1" ? "seat" : "seats"}
                </li>
                {p.features.map((f) => (
                  <li>
                    <span class="plan-check">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                    {f}
                  </li>
                ))}
              </ul>

              <a href="/signup" class={p.featured ? "btn btn-primary" : "btn btn-secondary"} style="width:100%;">
                Start free trial
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </article>
          ))}
        </div>

        <div class="enterprise-row" data-reveal>
          <div class="enterprise-row-left">
            <div class="enterprise-title">Multi-market brokerage? Custom volume & integrations.</div>
            <div class="enterprise-note">Lists refresh weekly — <span>only net-new contacts count against your cap.</span></div>
          </div>
          <a href="mailto:sales@realestateintent.com" class="btn btn-secondary">
            Contact sales
            <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- 5. FINAL CTA -->
    <section class="cta" id="cta">
      <div class="cta-glow"></div>
      <div class="container">
        <div class="cta-inner">
          <h2 class="cta-h2" data-reveal>
            The signal is already there. <em data-reveal-em>You just need to see it.</em>
          </h2>
          <div style="display:flex; justify-content:center; margin-top:8px;">
            <a href="/signup" class="btn btn-primary">
              Start 7-day free trial
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. FOOTER -->
    <footer class="footer">
      <div class="container">
        <div class="footer-row">
          <Logo />
          <nav class="footer-nav" aria-label="Footer">
            <a href="#pricing">pricing</a>
            <a href="/signup">sign in</a>
            <a href="/signup">start trial</a>
          </nav>
          <div class="caption">powered by <a href="https://gonextlevel.ai" style="color:var(--text-2);">Go Next Level</a></div>
        </div>
        <div class="footer-legal">
          <span>© 2025 Real Estate Intent</span>
          <span><a href="/privacy">Privacy</a> · <a href="/terms">Terms</a></span>
        </div>
      </div>
    </footer>
  </main>

  <!-- GSAP CDN — used only for the CTA gradient reveal -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>

  <script>
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // @ts-ignore
    const gsap = (window as any).gsap;
    // @ts-ignore
    const ScrollTrigger = (window as any).ScrollTrigger;
    if (gsap && ScrollTrigger) gsap.registerPlugin(ScrollTrigger);

    /* ===== Topbar scrolled state ===== */
    const topbar = document.querySelector<HTMLElement>(".topbar");
    const onScroll = () => {
      if (!topbar) return;
      topbar.classList.toggle("is-scrolled", window.scrollY > 4);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    /* ===== Reveal (hero stagger + scroll-triggered) ===== */
    const hero = document.querySelector(".hero");
    const heroReveals = hero ? Array.from(hero.querySelectorAll<HTMLElement>("[data-reveal]")) : [];
    const otherReveals = Array.from(document.querySelectorAll<HTMLElement>("[data-reveal]")).filter(
      (el) => !(hero && hero.contains(el))
    );

    heroReveals.forEach((el) => el.classList.add("reveal"));
    otherReveals.forEach((el) => el.classList.add("reveal"));

    if (prefersReduced) {
      document.querySelectorAll<HTMLElement>(".reveal").forEach((el) => el.classList.add("is-in"));
    } else {
      heroReveals.forEach((el, i) => {
        (el as HTMLElement).style.transitionDelay = `${i * 90 + 100}ms`;
        requestAnimationFrame(() => el.classList.add("is-in"));
      });

      if ("IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add("is-in");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
        );
        otherReveals.forEach((el) => io.observe(el));
      }
    }

    /* ===== CTA gradient reveal ===== */
    if (gsap && ScrollTrigger && !prefersReduced) {
      const em = document.querySelector<HTMLElement>("[data-reveal-em]");
      if (em) {
        ScrollTrigger.create({
          trigger: em,
          start: "top 80%",
          end: "top 30%",
          scrub: 0.4,
          onUpdate: (self: any) => {
            em.style.setProperty("--reveal", String(self.progress));
          },
          onLeave: () => em.classList.add("reveal-done"),
        });
      }
    } else {
      const em = document.querySelector<HTMLElement>("[data-reveal-em]");
      if (em) em.classList.add("reveal-done");
    }
  </script>
</BaseLayout>
