---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Logo from '../components/Logo.astro';
import ParticleField from '../components/ParticleField.astro';
import SignalTicker from '../components/SignalTicker.astro';

const businessName = "Real Estate Intent";
const tagline = "Behavioral Audience Intelligence for Real Estate";
const description = "Identify buyers, sellers, and distressed homeowners who are actively showing intent — before they hit Zillow. 60B+ behavioral signals weekly. 7-day free trial.";
const siteUrl = (Astro.site ?? Astro.url.origin).toString();

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": businessName,
      "url": siteUrl,
      "logo": `${siteUrl}favicon.svg`,
      "parentOrganization": { "@type": "Organization", "name": "Go Next Level" }
    },
    {
      "@type": "SoftwareApplication",
      "name": businessName,
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": description,
      "offers": [
        { "@type": "Offer", "name": "Starter", "price": "1000", "priceCurrency": "USD" },
        { "@type": "Offer", "name": "Growth", "price": "2500", "priceCurrency": "USD" },
        { "@type": "Offer", "name": "Scale", "price": "5000", "priceCurrency": "USD" }
      ]
    }
  ]
};

const behaviors = [
  {
    accent: "distress", title: "Distress",
    desc: "Actively engaging with pre-foreclosure content, loan modification, and financial hardship resources.",
    stat: "820", unit: "avg contacts / market / mo",
    spark: "M 0 28 L 10 24 L 18 26 L 28 18 L 38 22 L 48 14 L 58 18 L 68 10 L 80 14 L 92 6 L 100 8",
  },
  {
    accent: "seller", title: "Seller",
    desc: "Browsing listing platforms, researching home values, comparing agent reviews.",
    stat: "1,340", unit: "avg contacts / market / mo",
    spark: "M 0 24 L 12 20 L 22 22 L 32 16 L 44 18 L 54 12 L 64 14 L 74 8 L 86 10 L 100 4",
  },
  {
    accent: "buyer", title: "Buyer",
    desc: "Saving listings, attending virtual open houses, researching neighborhoods.",
    stat: "2,180", unit: "avg contacts / market / mo",
    spark: "M 0 26 L 10 18 L 22 22 L 32 14 L 42 16 L 54 8 L 64 12 L 76 6 L 88 10 L 100 4",
  },
  {
    accent: "mortgage", title: "Mortgage",
    desc: "Running affordability calculators, comparing lenders, engaging with refinance tools.",
    stat: "910", unit: "avg contacts / market / mo",
    spark: "M 0 22 L 12 24 L 22 18 L 34 20 L 44 14 L 56 16 L 66 10 L 78 12 L 90 6 L 100 10",
  },
];

const steps = [
  { n: "01", title: "Monitor", body: "60B+ real behaviors scanned weekly. Never sampled, never modeled." },
  { n: "02", title: "Filter",  body: "Category. Market. Recency. Export-ready in under a minute." },
  { n: "03", title: "Export",  body: "CSV or direct CRM push. Refresh weekly, only pay for net-new." },
];

const exportCats = [
  { cat: "distress", color: "#F87171" },
  { cat: "buyer",    color: "#4ADE80" },
  { cat: "seller",   color: "#FBBF24" },
  { cat: "mortgage", color: "#A78BFA" },
  { cat: "buyer",    color: "#4ADE80" },
  { cat: "seller",   color: "#FBBF24" },
  { cat: "distress", color: "#F87171" },
  { cat: "buyer",    color: "#4ADE80" },
];
const exportRows = exportCats.map((r, i) => ({
  cat: r.cat.toUpperCase(),
  color: r.color,
  y: 90 + i * 28,
  id: String(9142 + i).padStart(5, "0"),
}));

const plans = [
  { name: "Starter", price: "$1,000", contacts: "1,000", seats: "1", featured: false,
    features: ["All four intent categories", "CSV export + CRM push", "Weekly behavioral refresh", "7-day free trial"] },
  { name: "Growth",  price: "$2,500", contacts: "3,500", seats: "3", featured: true,
    features: ["Everything in Starter", "Auto-refreshing lists", "Multi-market builds", "Priority support"] },
  { name: "Scale",   price: "$5,000", contacts: "10,000", seats: "10", featured: false,
    features: ["Everything in Growth", "Dedicated success manager", "Custom CRM integrations", "Volume pricing"] },
];
---

<BaseLayout
  title={`${businessName} — ${tagline}`}
  description={description}
  structuredData={structuredData}
>
  <!-- Custom cursor -->
  <div class="cursor-ring" aria-hidden="true"></div>
  <div class="cursor-dot" aria-hidden="true"></div>

  <Topbar />

  <main>
    <!-- 1. HERO -->
    <section class="hero" id="hero">
      <div class="hero-glow"></div>
      <ParticleField />
      <div class="hero-vignette"></div>

      <div class="container hero-inner">
        <span class="chip" data-reveal>
          <span style="width:6px;height:6px;border-radius:50%;background:var(--brand);box-shadow:0 0 8px var(--brand);"></span>
          Audience intelligence for real estate
        </span>

        <h1 class="hero-h1" data-reveal>
          Real behaviors. Real contacts. <em class="gradient-text">Before</em> they hit Zillow.
        </h1>

        <p class="lead hero-lead" data-reveal>
          We monitor 60B+ weekly behavioral signals and turn them into verified, contactable leads — sliced by intent category and market.
        </p>

        <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center;" data-reveal>
          <span class="chip chip-live">
            <span class="pulse-dot"></span>
            live · 1,247 signals/min
          </span>
        </div>

        <div style="display:flex; flex-wrap:wrap; gap:10px; align-items:center;" data-reveal>
          <a href="/signup" class="btn btn-primary" data-magnetic>
            Start 7-day free trial
            <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/signup" class="btn btn-secondary">Sign in</a>
        </div>
      </div>
    </section>

    <SignalTicker />

    <!-- 2. FOUR BEHAVIORS -->
    <section class="section" id="behaviors">
      <div class="container">
        <div class="section-head">
          <span class="eyebrow" data-reveal>Four behaviors. One contact list.</span>
          <h2 class="section-title" data-reveal>
            Not <em class="gradient-text">who</em> they are. <em class="gradient-text">What</em> they're doing.
          </h2>
        </div>

        <div class="behaviors-grid">
          {behaviors.map((b) => (
            <article class="behavior-card" data-accent={b.accent} data-reveal>
              <div class="behavior-top">
                <span class={`tag tag-${b.accent}`}>{b.title}</span>
                <span class="caption" style={`color:var(--${b.accent});`}>
                  <span class="pulse-dot" style={`background:var(--${b.accent}); box-shadow:0 0 8px var(--${b.accent}); width:6px; height:6px;`}></span>
                </span>
              </div>
              <div class="behavior-body">
                <h3 class="behavior-title">{b.title}</h3>
                <p class="behavior-desc">{b.desc}</p>
              </div>
              <div class="behavior-foot">
                <div class="behavior-stat">
                  <strong class="mono" data-count-to={b.stat}>{b.stat}</strong>
                  <span style="color:var(--text-3); display:block; font-size:11px; letter-spacing:0.04em; text-transform:uppercase; margin-top:2px;">{b.unit}</span>
                </div>
                <svg class="sparkline" viewBox="0 0 100 36" preserveAspectRatio="none">
                  <path d={b.spark} />
                </svg>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. HOW IT WORKS (pinned) -->
    <section class="how" id="how">
      <div class="how-pin" data-pin>
        <div class="container">
          <div class="section-head" style="margin-bottom:40px;" data-reveal>
            <span class="eyebrow">How it works</span>
            <h2 class="section-title">
              From signal to verified contact in <em class="gradient-text">60 seconds</em>.
            </h2>
          </div>

          <div class="how-grid">
            <div class="how-stage" data-reveal>
              <div class="how-stage-inner">
                <!-- Panel 1: Monitor -->
                <div class="stage-panel is-active" data-panel="0">
                  <svg width="100%" height="100%" viewBox="0 0 360 360" preserveAspectRatio="xMidYMid meet">
                    <defs>
                      <radialGradient id="mg" cx="50%" cy="50%" r="50%"><stop offset="0" stop-color="rgba(167,139,250,0.22)"/><stop offset="1" stop-color="rgba(167,139,250,0)"/></radialGradient>
                    </defs>
                    <rect x="0" y="0" width="360" height="360" fill="url(#mg)"/>
                    <g class="mon-particles">
                      {[...Array(40)].map((_, i) => {
                        const cx = 20 + (i * 37) % 320;
                        const cy = 20 + ((i * 53) % 320);
                        const r = 1 + (i % 3);
                        const colors = ["#F87171","#FBBF24","#4ADE80","#A78BFA","#7DD3FC"];
                        return <circle cx={cx} cy={cy} r={r} fill={colors[i % 5]} opacity="0.7" />;
                      })}
                    </g>
                    <g stroke="rgba(255,255,255,0.08)" stroke-width="1">
                      <line x1="0" y1="180" x2="360" y2="180" />
                      <line x1="180" y1="0" x2="180" y2="360" />
                    </g>
                  </svg>
                </div>
                <!-- Panel 2: Filter (funnel) -->
                <div class="stage-panel" data-panel="1">
                  <svg width="100%" height="100%" viewBox="0 0 360 360" preserveAspectRatio="xMidYMid meet">
                    <g class="filter-bars">
                      <rect x="40"  y="60"  width="280" height="44" rx="8" fill="rgba(167,139,250,0.15)" stroke="rgba(167,139,250,0.35)" />
                      <rect x="80"  y="130" width="200" height="44" rx="8" fill="rgba(125,211,252,0.15)" stroke="rgba(125,211,252,0.35)" />
                      <rect x="120" y="200" width="120" height="44" rx="8" fill="rgba(74,222,128,0.18)"  stroke="rgba(74,222,128,0.45)" />
                      <rect x="150" y="270" width="60"  height="44" rx="8" fill="rgba(251,191,36,0.22)"  stroke="rgba(251,191,36,0.5)" />
                    </g>
                    <g font-family="JetBrains Mono" font-size="11" fill="rgba(255,255,255,0.55)">
                      <text x="56" y="87">CATEGORY · 12,482 signals</text>
                      <text x="96" y="157">MARKET · 4,921 signals</text>
                      <text x="136" y="227">RECENCY · 1,204 signals</text>
                      <text x="160" y="297" fill="#FBBF24">284 net-new</text>
                    </g>
                  </svg>
                </div>
                <!-- Panel 3: Export -->
                <div class="stage-panel" data-panel="2">
                  <svg width="100%" height="100%" viewBox="0 0 360 360" preserveAspectRatio="xMidYMid meet">
                    <rect x="40" y="40" width="280" height="280" rx="10" fill="rgba(23,23,26,0.8)" stroke="rgba(255,255,255,0.08)"/>
                    <rect x="40" y="40" width="280" height="30" fill="rgba(30,30,34,0.9)"/>
                    <text x="54" y="60" font-family="JetBrains Mono" font-size="10" fill="rgba(255,255,255,0.55)" letter-spacing="1">list-2026-04-21.csv</text>
                    {exportRows.map((row) => (
                      <g>
                        <rect x="50" y={row.y} width="56" height="16" rx="8" fill={`${row.color}22`} stroke={`${row.color}55`}/>
                        <text x="58" y={row.y + 11} font-family="JetBrains Mono" font-size="8" fill={row.color} letter-spacing="1">{row.cat}</text>
                        <text x="118" y={row.y + 11} font-family="JetBrains Mono" font-size="10" fill="rgba(255,255,255,0.82)">contact_{row.id}</text>
                        <text x="240" y={row.y + 11} font-family="JetBrains Mono" font-size="10" fill="#4ADE80">verified</text>
                      </g>
                    ))}
                  </svg>
                </div>
              </div>
            </div>

            <div class="how-steps" data-how-steps>
              {steps.map((s, i) => (
                <div class={`how-step ${i === 0 ? "is-active" : ""}`} data-step={i}>
                  <div class="how-step-head">
                    <span class="how-step-num mono">{s.n}</span>
                    <span class="how-step-title">{s.title}</span>
                  </div>
                  <p class="how-step-body">{s.body}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. PRICING -->
    <section class="section" id="pricing">
      <div class="container">
        <div class="section-head" style="text-align:center; align-items:center; margin-left:auto; margin-right:auto;">
          <span class="eyebrow" data-reveal>Pricing</span>
          <h2 class="section-title" data-reveal>Start free. <em class="gradient-text">Scale</em> when you're ready.</h2>
          <p class="lead" data-reveal style="max-width:500px;">7-day free trial on every plan.</p>
        </div>

        <div class="plan-grid">
          {plans.map((p) => (
            <article class="plan-card" data-featured={p.featured} data-reveal>
              {p.featured && <span class="plan-badge">Most popular</span>}
              <div>
                <h3 class="plan-name">{p.name}</h3>
                <div class="plan-price">
                  <span class="price">{p.price}</span>
                  <span class="price-suffix">/ mo</span>
                </div>
              </div>

              <div class="plan-meta-row">
                <div>
                  <div class="plan-meta-label">Contacts</div>
                  <div class="plan-meta-value">{p.contacts}<span> / mo</span></div>
                </div>
                <div>
                  <div class="plan-meta-label">Seats</div>
                  <div class="plan-meta-value">{p.seats}</div>
                </div>
              </div>

              <ul class="plan-features">
                {p.features.map((f) => (
                  <li>
                    <span class="plan-check">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                    {f}
                  </li>
                ))}
              </ul>

              <a href="/signup" class={p.featured ? "btn btn-primary" : "btn btn-secondary"} style="width:100%;" data-magnetic={p.featured ? "true" : null}>
                Start free trial
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </article>
          ))}
        </div>

        <div class="enterprise-row" data-reveal>
          <div class="enterprise-row-left">
            <div class="enterprise-title">Multi-market brokerage? Custom volume & integrations.</div>
            <div class="enterprise-note">Lists refresh weekly — <span>only net-new contacts count against your cap.</span></div>
          </div>
          <a href="mailto:sales@realestateintent.com" class="btn btn-secondary">
            Contact sales
            <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- 5. FINAL CTA -->
    <section class="cta" id="cta">
      <div class="cta-glow"></div>
      <div class="container">
        <div class="cta-inner">
          <h2 class="cta-h2" data-reveal>
            The signal is already there. <em data-reveal-em>You just need to see it.</em>
          </h2>
          <div style="display:flex; justify-content:center; margin-top:8px;">
            <a href="/signup" class="btn btn-primary" data-magnetic>
              Start 7-day free trial
              <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. FOOTER -->
    <footer class="footer">
      <div class="container">
        <div class="footer-row">
          <Logo />
          <nav class="footer-nav" aria-label="Footer">
            <a href="#pricing">pricing</a>
            <a href="/signup">sign in</a>
            <a href="/signup">start trial</a>
          </nav>
          <div class="caption">powered by <a href="https://gonextlevel.ai" style="color:var(--text-2);">Go Next Level</a></div>
        </div>
        <div class="footer-legal">
          <span>© 2025 Real Estate Intent</span>
          <span><a href="/privacy">Privacy</a> · <a href="/terms">Terms</a></span>
        </div>
      </div>
    </footer>
  </main>

  <!-- GSAP CDN -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>

  <script>
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isTouch = window.matchMedia("(hover: none), (pointer: coarse)").matches;

    // @ts-ignore
    const gsap = (window as any).gsap;
    // @ts-ignore
    const ScrollTrigger = (window as any).ScrollTrigger;
    if (gsap && ScrollTrigger) gsap.registerPlugin(ScrollTrigger);

    /* ===== Topbar scrolled state ===== */
    const topbar = document.querySelector<HTMLElement>(".topbar");
    const onScroll = () => {
      if (!topbar) return;
      topbar.classList.toggle("is-scrolled", window.scrollY > 4);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    /* ===== Reveal (hero stagger + scroll-triggered) ===== */
    const hero = document.querySelector(".hero");
    const heroReveals = hero ? Array.from(hero.querySelectorAll<HTMLElement>("[data-reveal]")) : [];
    const otherReveals = Array.from(document.querySelectorAll<HTMLElement>("[data-reveal]")).filter(
      (el) => !(hero && hero.contains(el))
    );

    // Hero stagger
    heroReveals.forEach((el) => el.classList.add("reveal"));
    otherReveals.forEach((el) => el.classList.add("reveal"));

    if (prefersReduced) {
      document.querySelectorAll<HTMLElement>(".reveal").forEach((el) => el.classList.add("is-in"));
    } else {
      heroReveals.forEach((el, i) => {
        (el as HTMLElement).style.transitionDelay = `${i * 80 + 80}ms`;
        requestAnimationFrame(() => el.classList.add("is-in"));
      });

      if ("IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add("is-in");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
        );
        otherReveals.forEach((el) => io.observe(el));
      }
    }

    /* ===== Counter animation ===== */
    if (!prefersReduced && "IntersectionObserver" in window) {
      const counters = document.querySelectorAll<HTMLElement>("[data-count-to]");
      const counterIo = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const el = entry.target as HTMLElement;
            const target = el.dataset.countTo || "";
            const numericMatch = target.match(/[\d,]+/);
            if (numericMatch) {
              const clean = parseFloat(numericMatch[0].replace(/,/g, ""));
              const duration = 1100;
              const start = performance.now();
              const ease = (t: number) => 1 - Math.pow(1 - t, 3);
              const step = (now: number) => {
                const t = Math.min(1, (now - start) / duration);
                const v = Math.round(clean * ease(t));
                el.textContent = v.toLocaleString("en-US");
                if (t < 1) requestAnimationFrame(step);
                else el.textContent = target;
              };
              requestAnimationFrame(step);
            }
            counterIo.unobserve(el);
          }
        },
        { threshold: 0.4 }
      );
      counters.forEach((el) => counterIo.observe(el));
    }

    /* ===== Custom cursor ===== */
    if (!isTouch && !prefersReduced) {
      const dot = document.querySelector<HTMLElement>(".cursor-dot");
      const ring = document.querySelector<HTMLElement>(".cursor-ring");
      if (dot && ring) {
        let dx = 0, dy = 0, rx = 0, ry = 0, mx = 0, my = 0;
        const setDot = gsap ? gsap.quickTo(dot, "x", { duration: 0.05, ease: "none" }) : null;
        const setDotY = gsap ? gsap.quickTo(dot, "y", { duration: 0.05, ease: "none" }) : null;
        const setRing = gsap ? gsap.quickTo(ring, "x", { duration: 0.28, ease: "power3" }) : null;
        const setRingY = gsap ? gsap.quickTo(ring, "y", { duration: 0.28, ease: "power3" }) : null;

        window.addEventListener("mousemove", (e) => {
          mx = e.clientX; my = e.clientY;
          document.body.classList.add("cursor-ready");
          if (gsap && setDot && setDotY && setRing && setRingY) {
            setDot(mx); setDotY(my);
            setRing(mx); setRingY(my);
          } else {
            dot.style.transform = `translate(${mx}px, ${my}px) translate(-50%, -50%)`;
            ring.style.transform = `translate(${mx}px, ${my}px) translate(-50%, -50%)`;
          }
        });

        document.querySelectorAll<HTMLElement>("a, button, [data-magnetic]").forEach((el) => {
          el.addEventListener("mouseenter", () => document.body.classList.add("cursor-hover"));
          el.addEventListener("mouseleave", () => document.body.classList.remove("cursor-hover"));
        });
      }
    }

    /* ===== Magnetic buttons ===== */
    if (!isTouch && !prefersReduced && gsap) {
      document.querySelectorAll<HTMLElement>("[data-magnetic]").forEach((el) => {
        const xTo = gsap.quickTo(el, "x", { duration: 0.45, ease: "elastic.out(1, 0.5)" });
        const yTo = gsap.quickTo(el, "y", { duration: 0.45, ease: "elastic.out(1, 0.5)" });
        el.addEventListener("mousemove", (e: MouseEvent) => {
          const r = el.getBoundingClientRect();
          const cx = r.left + r.width / 2;
          const cy = r.top + r.height / 2;
          const dx = (e.clientX - cx) * 0.3;
          const dy = (e.clientY - cy) * 0.35;
          xTo(dx); yTo(dy);
        });
        el.addEventListener("mouseleave", () => {
          xTo(0); yTo(0);
        });
      });
    }

    /* ===== How It Works pinned scroll ===== */
    if (gsap && ScrollTrigger && !prefersReduced && window.matchMedia("(min-width: 900px)").matches) {
      const howPin = document.querySelector<HTMLElement>(".how-pin");
      const panels = document.querySelectorAll<HTMLElement>("[data-panel]");
      const stepEls = document.querySelectorAll<HTMLElement>(".how-step");

      if (howPin && panels.length && stepEls.length) {
        ScrollTrigger.create({
          trigger: howPin,
          start: "top top",
          end: "+=1800",
          pin: true,
          scrub: 0.6,
          onUpdate: (self: any) => {
            const p = self.progress;
            let idx = 0;
            if (p > 0.66) idx = 2;
            else if (p > 0.33) idx = 1;
            else idx = 0;
            panels.forEach((el, i) => el.classList.toggle("is-active", i === idx));
            stepEls.forEach((el, i) => el.classList.toggle("is-active", i === idx));
          },
        });
      }
    }

    /* ===== CTA gradient reveal ===== */
    if (gsap && ScrollTrigger && !prefersReduced) {
      const em = document.querySelector<HTMLElement>("[data-reveal-em]");
      if (em) {
        ScrollTrigger.create({
          trigger: em,
          start: "top 80%",
          end: "top 30%",
          scrub: 0.4,
          onUpdate: (self: any) => {
            em.style.setProperty("--reveal", String(self.progress));
          },
          onLeave: () => em.classList.add("reveal-done"),
        });
      }
    } else {
      const em = document.querySelector<HTMLElement>("[data-reveal-em]");
      if (em) em.classList.add("reveal-done");
    }
  </script>
</BaseLayout>
