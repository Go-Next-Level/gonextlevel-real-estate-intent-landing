<script>
  // Scroll reveal — respecting prefers-reduced-motion
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const reveals = document.querySelectorAll<HTMLElement>(".reveal");

  if (prefersReduced) {
    reveals.forEach((el) => el.classList.add("is-in"));
  } else if ("IntersectionObserver" in window) {
    // Hero stagger
    const hero = document.querySelector(".hero");
    const heroReveals = hero ? Array.from(hero.querySelectorAll<HTMLElement>(".reveal")) : [];
    heroReveals.forEach((el, i) => {
      el.style.transitionDelay = `${i * 60}ms`;
      requestAnimationFrame(() => el.classList.add("is-in"));
    });

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.classList.add("is-in");
            io.unobserve(el);
          }
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
    );

    reveals.forEach((el) => {
      if (hero && hero.contains(el)) return;
      io.observe(el);
    });

    // Stat counters
    const statEls = document.querySelectorAll<HTMLElement>("[data-count-to]");
    const statObs = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const el = entry.target as HTMLElement;
          const target = el.dataset.countTo || "";
          animateCounter(el, target);
          statObs.unobserve(el);
        }
      },
      { threshold: 0.4 }
    );
    statEls.forEach((el) => statObs.observe(el));

    function animateCounter(el: HTMLElement, final: string) {
      const numericMatch = final.match(/[\d.]+/);
      if (!numericMatch) return;
      const raw = parseFloat(numericMatch[0]);
      const prefix = final.slice(0, final.indexOf(numericMatch[0]));
      const suffix = final.slice(final.indexOf(numericMatch[0]) + numericMatch[0].length);
      const duration = 1100;
      const start = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      const step = (now: number) => {
        const t = Math.min(1, (now - start) / duration);
        const v = raw * ease(t);
        const display = final.includes(".")
          ? v.toFixed(1)
          : Math.round(v).toString();
        el.textContent = `${prefix}${display}${suffix}`;
        if (t < 1) requestAnimationFrame(step);
        else el.textContent = final;
      };
      requestAnimationFrame(step);
    }
  } else {
    reveals.forEach((el) => el.classList.add("is-in"));
  }
</script>
