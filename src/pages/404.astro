---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
---

<BaseLayout
  title="Page not found — Real Estate Intent"
  description="The page you're looking for doesn't exist."
>
  <Topbar />
  <main class="notfound">
    <div class="grid-bg"></div>
    <div class="hero-glow"></div>
    <div class="container nf-inner">
      <span class="caption">error · 404</span>
      <h1 class="nf-title">No signal here.</h1>
      <p class="lead nf-body">
        The page you're looking for isn't in our index. Head back to build your next list.
      </p>
      <div class="cta-row" style="margin-top:24px;">
        <a href="/" class="btn btn-primary">
          Back to home
          <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/#pricing" class="btn btn-secondary">See pricing</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .notfound {
    position: relative;
    min-height: calc(100vh - 52px);
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 80px 0;
  }
  .nf-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
  }
  .nf-title {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-top: 6px;
  }
  .nf-body { max-width: 520px; }
</style>
